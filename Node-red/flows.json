rr":0,"initialize":"","finalize":"","libs":[],"x":240,"y":180,"wires":[["192a57b507d0ee05","43db15dc7188fc9f"],["75a29f06d9dd0573"],["e59d6541694c63d5"]]},{"id":"192a57b507d0ee05","type":"debug","z":"1aae591023126ad8","name":"","active":false,"tosidebar":true,"console":false,"tostatus":false,"complete":"true","x":490,"y":60,"wires":[]},{"id":"043d166b2253c4a9","type":"ui_template","z":"1aae591023126ad8","group":"44d157652ab6a30f","name":"Bubble (dynamic)","order":1,"width":9,"height":10,"format":"","storeOutMessages":false,"fwdInMessages":true,"resendOnRefresh":false,"templateScope":"local","className":"","x":190,"y":340,"wires":[[]]},{"id":"efd4b6866f98ca08","type":"link in","z":"1aae591023126ad8","name":"link in 1","links":["39391dd440826fed"],"x":125,"y":100,"wires":[["dfecf0def4a474c3","9026e13136f7c2ba"]]},{"id":"9026e13136f7c2ba","type":"debug","z":"1aae591023126ad8","name":"debug 8","active":false,"tosidebar":true,"console":false,"tostatus":false,"complete":"false","statusVal":"","statusType":"auto","x":280,"y":100,"wires":[]},{"id":"8c94f63f3079a161","type":"ui_template","z":"1aae591023126ad8","d":true,"group":"44d157652ab6a30f","name":"trayectoria","order":2,"width":0,"height":0,"format":"<!DOCTYPE html>\n<html lang=\"es\">\n<head>\n    <meta charset=\"UTF-8\">\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n    <title>Ejemplo de setInterval</title>\n    <style>\n        canvas {\n            border: 1px solid black;\n        }\n    </style>\n</head>\n<body>\n    <canvas id=\"trayectoriaCanvas\" width=\"600\" height=\"600\"></canvas>\n    <script>\n        // Datos de la trayectoria en un buffer (array)\n        let buffer = [\n            {x: 0, y: 0},\n            {x: 0, y: 0},\n            // Agrega más puntos según sea necesario\n        ];\n\n        // Obtener el contexto del canvas\n        const canvas = document.getElementById('trayectoriaCanvas');\n        const ctx = canvas.getContext('2d');\n\n        // Función para dibujar la trayectoria\n        function dibujarTrayectoria(buffer) {\n            ctx.clearRect(0, 0, canvas.width, canvas.height); // Limpiar el canvas\n            if (buffer.length > 1) {\n                ctx.beginPath();\n                ctx.moveTo(buffer[0].x, buffer[0].y);\n                \n                for (let i = 1; i < buffer.length; i++) {\n                    ctx.lineTo(buffer[i].x, buffer[i].y);\n                }\n\n                ctx.strokeStyle = 'blue';\n                ctx.lineWidth = 2;\n                ctx.stroke();\n                ctx.closePath();\n            }\n        }\n\n        var t=0;\n        // Función que se ejecutará periódicamente\n        function actualizarTrayectoria() {\n            // Aquí puedes actualizar el buffer o realizar otras acciones periódicas\n            t+=0.01;\n            buffer.push({x: (1+Math.sin(2*3.14*t)) * canvas.width/2, y: (1+Math.cos(2*3.14*t)) * canvas.height/2});\n            if (buffer.length > 10) {\n                buffer.shift(); // Elimina el primer punto si hay más de 10\n            }\n            dibujarTrayectoria(buffer);\n        }\n\n        // Ejecutar la función cada segundo (1000 milisegundos)\n        setInterval(actualizarTrayectoria, 100);\n    </script>\n</body>\n</html>","storeOutMessages":false,"fwdInMessages":false,"resendOnRefresh":false,"templateScope":"local","className":"","x":170,"y":380,"wires":[[]]},{"id":"43db15dc7188fc9f","type":"template","z":"1aae591023126ad8","name":"Create the msg.template to use 2.0","field":"template","fieldType":"msg","format":"html","syntax":"mustache","template":"<canvas id=\"bubble-chart\" width=\"400\" height=\"400\" style=\"border:1px solid #000000;\"></canvas>\n\n<script>\n    new Chart(document.getElementById(\"bubble-chart\"), {\n        type: 'bubble',\n        data: {\n            labels: \"label\",\n            datasets: [\n                {\n                    backgroundColor: \"rgba(65, 72, 255, 1.0000)\",\n                    borderColor: \"#000\",\n                    data: [\n                        {{{payload.data}}}\n                    ]\n                }\n            ]\n        },\n        options: {\n            animation: {\n                duration: 0 // Desactiva las animaciones\n            },\n            legend: {\n                display: false\n            },\n            title: {\n                display: true,\n                text: '{{{payload.title}}}'\n            },\n            scales: {\n                yAxes: [{\n                    scaleLabel: {\n                        display: true,\n                        labelString: \"Eje Y\"\n                    },\n                    ticks: {\n                        min: -15,\n                        max: 15,\n                        stepSize: 3 // Marca los valores de a 1\n                    },\n                    gridLines: {\n                        display: true,\n                        color: \"#ccc\", // Color de las líneas de la grilla\n                        lineWidth: 0.5 // Ancho de las líneas de la grilla\n                    }\n                }],\n                xAxes: [{\n                    scaleLabel: {\n                        display: true,\n                        labelString: \"Eje X\"\n                    },\n                    ticks: {\n                        min: -15,\n                        max: 15,\n                        stepSize: 3, // Marca los valores de a 1\n                        callback: function(value) { // Alinea los valores horizontalmente\n                            return value;\n                        }\n                    },\n                    gridLines: {\n                        display: true,\n                        color: \"#ccc\", // Color de las líneas de la grilla\n                        lineWidth: 0.5 // Ancho de las líneas de la grilla\n                    }\n                }]\n            }\n        }\n    });\n</script>\n","output":"str","x":240