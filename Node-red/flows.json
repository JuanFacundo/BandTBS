","type":"function","z":"2429be65163edb77","name":"function 4","func":"// Inicializar variables\nvar msg_data = \"\";\nvar msg_posicion = \"\";\n\n// Obtener el mensaje recibido por puerto serie\nvar msg_received = msg.payload;\n\n// Buscar la posición del primer '[' y '{'\nvar data_start = msg_received.indexOf('[');\nvar posicion_start = msg_received.indexOf('{');\n\n// Verificar si se encontraron '[' y '{'\nif (data_start != -1 && posicion_start != -1) {\n    // Extraer los datos\n    msg_data = msg_received.substring(data_start, posicion_start).trim();\n\n    // Extraer la posición\n    msg_posicion = msg_received.substring(posicion_start).trim();\n\n    // Verificar y corregir el formato JSON\n    try {\n        // Intentar analizar msg_posicion como JSON\n        var parsed_posicion = JSON.parse(msg_posicion);\n        \n        // Crear dos nuevos mensajes para las partes separadas\n        var msg_data_out = { payload: msg_data };\n        var msg_posicion_out = { payload: parsed_posicion };\n\n        // Enviar los mensajes separados a las salidas correspondientes\n        return [msg_data_out, msg_posicion_out];\n    } catch (error) {\n        // En caso de error de sintaxis en JSON, emitir un mensaje de error\n        node.error(\"Error de sintaxis en JSON: \" + error.message);\n        return null;\n    }\n} else {\n    // En caso de no encontrar los caracteres esperados, emitir un mensaje de error\n    node.error(\"Error: No se encontraron '[' o '{' en el mensaje recibido.\");\n    return null;\n}","outputs":2,"timeout":0,"noerr":0,"initialize":"","finalize":"","libs":[],"x":240,"y":220,"wires":[["08a4f9a94f732c6e"],["39391dd440826fed","58dc1747f0805c48"]]},{"id":"39391dd440826fed","type":"link out","z":"2429be65163edb77","name":"link out 1","mode":"link","links":["efd4b6866f98ca08","0b35f24379e83e65","41535c6ea46c3258","8a498e310448359e","17de09bfa30f9f2b","6d9a8cb8c908abd1","6dcf57013c6ffe1c","b60131aff86107c8"],"x":365,"y":180,"wires":[]},{"id":"9e94d